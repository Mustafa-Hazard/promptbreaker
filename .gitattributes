# Normalize all text files to LF in the repo, regardless of OS checkout settings.
* text=auto eol=lf

# Windows batch files genuinely need CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
